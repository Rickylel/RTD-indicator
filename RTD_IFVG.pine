//@version=6
indicator("RTD IFVG", shorttitle="RTD IFVG", overlay=true, max_lines_count=500, max_boxes_count=500, max_labels_count=500, max_bars_back=2500)

// =============================================================================
// --- 1. GENERAL SETTINGS ---
// =============================================================================
grp_gen = "GENERAL SETTINGS"

detect_mode = input.string("Series", "Detection Mode", options=["Single", "Series"], tooltip="Series = Merges overlapping FVGs into one block. \nSeries = Displays each FVG individually." ,group=grp_gen, display=display.none)
sens_mode   = input.string("Sensitive", "Sensitivity", options=["Strict", "Normal", "Sensitive"], group=grp_gen, display=display.none)

len_piv = 5
if sens_mode == "Strict"
    len_piv := 10
else if sens_mode == "Sensitive"
    len_piv := 3

bias_input  = input.string("Neutro", "Bias", options=["Neutro", "Bullish", "Bearish"], group=grp_gen, display=display.none)
show_bull   = bias_input != "Bearish"
show_bear   = bias_input != "Bullish"

allow_15_ifvg = input.bool(true, "Allow 7-15 Candle IFVGs", tooltip="If enabled, IFVGS may form within 15 candles.\nIf disabled, they must form within 6 candles.", group=grp_gen, display=display.none)

rm_losing   = input.bool(true, "Remove Losing Setups", tooltip="Removes trades that hit Original SL or are Scratched at Break-Even.", group=grp_gen, display=display.none)
// --- NUEVO: Botón para invalidar setups si se toca el BE prematuramente ---
req_be_safe = input.bool(true, "Require BE not breached in inversion", tooltip="If enabled, the setup is invalidated if the entry candle sweeps the internal liquidity (BE) simultaneously.", group=grp_gen)
// --- NUEVO: Botón para ocultar o mostrar ganadores ---
show_winning = input.bool(true, "Show Winning Setups", tooltip="Keep setups on the chart after they hit their final Take Profit.", group=grp_gen, display=display.none)
// --- NUEVO: FVG Current TF como Pase VIP ---
include_curr_tf = input.bool(false, "Include Current TF in HTF PDAs", tooltip="Allows current timeframe FVGs to act as a 'VIP Pass' for entries, and prevents them from erasing higher timeframe FVGs on the chart.", group=grp_gen, display=display.none)
// --- TRADE MANAGEMENT INPUTS ---
use_frontrun_filter = input.bool(false, title="Enable Anti-Front-Run Filter", tooltip="Invalidates the setup if the entry candle is so massive that it instantly sweeps the first structural target (TP1/BE). Leave unchecked to catch Market Open displacements and Judas Swings.", group="Execution")

min_grade   = input.string("A", "Min RTD Grade to Display", options=["A+", "A", "A-", "B+", "B", "C"], group=grp_gen, display=display.none)
int req_g_val = 0
if min_grade == "B"
    req_g_val := 1
else if min_grade == "B+"
    req_g_val := 2
else if min_grade == "A-"
    req_g_val := 3
else if min_grade == "A"
    req_g_val := 4
else if min_grade == "A+"
    req_g_val := 5

max_show    = input.int(5, "Number of Setups Displayed", minval=1, group=grp_gen, display=display.none)

// VARIABLE GLOBAL DE TIEMPO
int one_bar_ms = timeframe.in_seconds(timeframe.period) * 1000

// =============================================================================
// --- 1.5 RISK MANAGEMENT & POSITION SIZE ---
