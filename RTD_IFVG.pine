grp_trade_kz = "STRICT KILLZONE FILTER"
use_kz = input.bool(true, "Enable Strict Killzone Filter", tooltip="Penalizes or blocks setups that occur outside of your active trading sessions.", group=grp_trade_kz)

// Solo los checkboxes para operar o no operar en esas sesiones 
// (Los colores, fondos y horarios ya se controlan en el Master Menu)
use_ny_am = input.bool(true, "Trade NY AM", inline="t1", group=grp_trade_kz)
trade_nyl = input.bool(false, "Trade NY Lunch", inline="t1", group=grp_trade_kz)
use_ny_pm = input.bool(true, "Trade NY PM", inline="t2", group=grp_trade_kz)
use_lon   = input.bool(false, "Trade London", inline="t2", group=grp_trade_kz)
use_asia  = input.bool(false, "Trade Asia", inline="t3", group=grp_trade_kz)

// --- RELOJ INTERNO DEL ALGORITMO (Conectado al Master Time) ---
