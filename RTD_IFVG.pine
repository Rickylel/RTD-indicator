in_am    = time(timeframe.period, t_nyam, "America/New_York") != 0
in_nyl   = time(timeframe.period, t_lunch, "America/New_York") != 0
in_pm    = time(timeframe.period, t_nypm, "America/New_York") != 0
in_lon   = time(timeframe.period, t_lon, "America/New_York") != 0
in_asia  = time(timeframe.period, t_asia, "America/New_York") != 0

// Variable global que le dice al motor si está autorizado para disparar una entrada ahora mismo
bool in_active_kz = (use_ny_am and in_am) or (trade_nyl and in_nyl) or (use_ny_pm and in_pm) or (use_lon and in_lon) or (use_asia and in_asia)

// =============================================================================
// --- 2. ADVANCED LIQUIDITY ---
// =============================================================================
grp_liq = "LIQUIDITY"

align_mode   = input.string("Automatic", "Alignment Mode", options=["Automatic", "Manual"], inline="align_grp", group=grp_liq)
align_tf     = input.string("15", "Timeframe", options=["5", "15", "60"], inline="align_grp", group=grp_liq, tooltip="Only active if Alignment Mode is 'Manual'. If set to 'Automatic', this box is completely ignored and the current chart timeframe is used.")
liq_swing_str = input.int(1, "Structural Pivot Strength", minval=1, maxval=10, tooltip="Higher = less noise, requires more bars to confirm. retail = 1, structural = 3 to 5.", group=grp_liq)

// --- NEW: Liquidity Levels Visibility (Matches your UI design) ---
show_liq     = input.bool(true, "Show Liquidity:", inline="liq_lvl", group=grp_liq, display=display.none)
c_bsl        = input.color(color.new(color.black, 40), "Buyside", inline="liq_lvl", group=grp_liq, display=display.none)
c_ssl        = input.color(color.new(color.black, 40), "Sellside", inline="liq_lvl", group=grp_liq, display=display.none)

liq_style_in = input.string("Dotted", "Line Style", options=["Solid", "Dashed", "Dotted"], inline="liq_style", group=grp_liq, display=display.none)
liq_lbl_sz_in= input.string("Tiny", "Label Size", options=["Tiny", "Small", "Normal"], inline="liq_style", group=grp_liq, display=display.none)
// --- NEW: Limit structural liquidity clutter ---
max_liq_lines = input.int(8, "Max Visible Levels", minval=1, maxval=50, tooltip="Limits the number of structural BSL/SSL lines drawn on the chart. Older lines are hidden but kept in the algorithm's memory.", group=grp_liq, display=display.none)

// --- Liquidity Sweeps ---
show_sweeps  = input.bool(true, "Show Liquidity Sweeps", inline="swp", group=grp_liq, display=display.none)
c_swp_line   = input.color(color.rgb(0, 0, 0), "", inline="swp", group=grp_liq, display=display.none)
max_swp      = input.int(3, "Max Visible Sweeps", minval=1, maxval=20, group=grp_liq, display=display.none)

// --- MACRO DATA HIGHS / LOWS (8:30 AM NY) ---
show_data_in = input.bool(true, "Show Data High/Low", inline="data1", group=grp_liq, display=display.none)
c_data       = input.color(color.new(color.black, 40), "", inline="data1", group=grp_liq, display=display.none)

data_style_in= input.string("Solid", "Data Line Style", options=["Solid", "Dashed", "Dotted"], inline="data2", group=grp_liq, display=display.none)

// Advanced Data Options
data_pts     = input.float(6.0, "Wick Size Threshold (Points)", tooltip="Minimum wick size in points to validate the 8:30 AM swing.", group=grp_liq, display=display.none)
data_lbl_sz  = input.string("Tiny", "Label Size", options=["Tiny", "Small", "Normal", "Large"], group=grp_liq, display=display.none)
c_data_lbl   = input.color(color.new(color.black, 40), "Label Text Color", group=grp_liq, display=display.none)
data_offset  = input.int(6, "Label Vertical Offset (Ticks)", tooltip="Distance to park the label after mitigation.", group=grp_liq, display=display.none)

data_del_mit = input.bool(false, "Delete on Mitigation", tooltip="If true, immediately deletes the visual on first touch. If false, freezes the line and parks the label centered beneath/above.", group=grp_liq, display=display.none)
data_cleanup = input.int(200, "Auto-cleanup after bars", tooltip="0 = disabled. Removes the unmitigated line after X bars to keep charts clean.", group=grp_liq, display=display.none)

// =============================================================================
// --- 2.1 REQH/L (RELATIVE EQUAL HIGHS & LOWS) ---
// =============================================================================
grp_reqh = "REQH/L"

show_reqh_in = input.bool(true, "Show REQH/L:", inline="reqh_colors", group=grp_reqh, display=display.none)
c_reqh_bsl   = input.color(color.new(#4a4a4a, 40), "Buyside", inline="reqh_colors", group=grp_reqh, display=display.none)
c_reqh_ssl   = input.color(color.new(#4a4a4a, 40), "Sellside", inline="reqh_colors", group=grp_reqh, display=display.none)

reqh_style_in= input.string("Solid", "Line Style", options=["Solid", "Dashed", "Dotted"], inline="reqh_style", group=grp_reqh, display=display.none)
reqh_lbl_sz  = input.string("Tiny", "Label Size", options=["Tiny", "Small", "Normal"], inline="reqh_style", group=grp_reqh, display=display.none)

show_reqh_lbl= input.bool(true, "Show Labels:", inline="reqh_lbl_pos", group=grp_reqh, display=display.none)
reqh_lbl_pos = input.string("Right", "Label Placement", options=["Right", "Left"], inline="reqh_lbl_pos", group=grp_reqh, display=display.none)

// Tolerancia institucional oculta a la vista para mantener la UI limpia (en Ticks)
reqh_ticks   = input.int(10, "Tolerance (Ticks)", tooltip="Maximum difference in ticks to consider highs/lows as 'Relative Equals'.", group=grp_reqh, display=display.none)

// =============================================================================
// --- 3. FAIR VALUE GAPS (CON HTF CE / MIDLINE ESTRICTO) ---
// =============================================================================
grp_fvg = "FAIR VALUE GAPS"

show_htf_fvg    = input.bool(true, "Show HTF FVGs", inline="fvg1", group=grp_fvg, display=display.none)
show_htf_border = input.bool(false, "Show Border", inline="fvg1", group=grp_fvg, display=display.none)
extend_htf      = input.int(10, "Extend HTF FVGs by X bars", group=grp_fvg, display=display.none)
max_htf_fvgs    = input.int(3, "Max HTF FVGs to Display", minval=1, maxval=50, group=grp_fvg, display=display.none)
clean_stacked   = input.bool(true, "Hide Nested FVGs (Clean Chart)", tooltip="If a lower timeframe FVG forms inside a higher timeframe FVG, the smaller one is hidden.", group=grp_fvg, display=display.none)

c_htf_lbl        = input.color(color.new(#000000, 35), "Label Color", inline="fvg2", group=grp_fvg, display=display.none)
sz_htf_lbl_in    = input.string("Tiny", "Label Size", options=["Auto", "Tiny", "Small", "Normal"], inline="fvg2", group=grp_fvg, display=display.none)

c_htf_bull      = input.color(color.new(#636363, 90), "Bullish Color", inline="fvg3", group=grp_fvg, display=display.none)
c_htf_bear      = input.color(color.new(#636363, 90), "Bearish Color", inline="fvg3", group=grp_fvg, display=display.none)

c_htf_inv_bull  = input.color(color.new(#2e2e2e, 85), "Inverted Color for Bullish Inversions", group=grp_fvg, display=display.none)
c_htf_inv_bear  = input.color(color.new(#2e2e2e, 85), "Inverted Color for Bearish Inversions", group=grp_fvg, display=display.none)

// --- HTF FVG MIDLINE (CE) INPUTS ---
show_htf_ce = input.bool(true, title="Show HTF FVG Midline (C.E.)", group="HTF FVG Settings")
htf_ce_color = input.color(color.new(color.gray, 30), title="Midline Color", inline="ce1", group="HTF FVG Settings")
htf_ce_style_str = input.string("Dashed", title="Midline Style", options=["Solid", "Dashed", "Dotted"], inline="ce1", group="HTF FVG Settings")

// Función para traducir el texto del menú a un estilo de línea
f_get_line_style(style_str) =>
    style_str == "Solid" ? line.style_solid : style_str == "Dashed" ? line.style_dashed : line.style_dotted

htf_ce_style = f_get_line_style(htf_ce_style_str)

show_htf_inv    = input.bool(true, "Display Inversion", group=grp_fvg, display=display.none)

var string sz_htf_lbl = size.tiny
if sz_htf_lbl_in == "Small"
    sz_htf_lbl := size.small
else if sz_htf_lbl_in == "Normal"
    sz_htf_lbl := size.normal
else if sz_htf_lbl_in == "Auto"
    sz_htf_lbl := size.auto

// 🌟 ACTUALIZACIÓN DEL TIPO: Añadimos 'midline' para que la línea viva dentro de la caja
type HtfFvg
    box bx
    line midline // <--- AQUI VIVIRÁ LA LÍNEA DEL CE
    float top
    float bot
    bool is_bull
    bool inverted
    string tf
    int last_time
    int last_index 

var htf_fvgs = array.new<HtfFvg>()

// 🌟 FUNCIÓN DE FUSIÓN DE FVGs (LIQUIDITY VOID MOTOR) 🌟
// Agregamos htf_atr a los parámetros
f_create_htf_fvg(h1, l1, h3, l3, t2, t1_index, tf_label, htf_atr) =>
    int right_time = time + (extend_htf * one_bar_ms) 
    bool merged = false

    bool is_bull_gap = l1 > h3
    bool is_bear_gap = h1 < l3
    float new_top = is_bull_gap ? l1 : (is_bear_gap ? l3 : na)
    float new_bot = is_bull_gap ? h3 : (is_bear_gap ? h1 : na)

    // 🌟 FILTRO ANTI-RUIDO (DISPLACEMENT FILTER) 🌟
    // 0.5 significa que el FVG debe medir al menos la mitad del movimiento normal de una vela (ATR).
    // Si quieres el gráfico AÚN MÁS LIMPIO, súbelo a 0.8 o 1.0. Si quieres ver más, bájalo a 0.3.
    float noise_multiplier = 0.5 
    if not na(htf_atr) and (new_top - new_bot) < (htf_atr * noise_multiplier)
        // El gap es demasiado pequeño. Lo matamos apagando sus variables antes de que nazca.
        is_bull_gap := false
        is_bear_gap := false

    int tf_mins = tf_label == "1H FVG" ? 60 : tf_label == "15M FVG" ? 15 : tf_label == "5M FVG" ? 5 : 0
    int max_time_dist = tf_mins * 60000 * 3

    // 1. INTENTAMOS FUSIONAR CON UNO EXISTENTE
    if (is_bull_gap or is_bear_gap) and array.size(htf_fvgs) > 0
        for i = array.size(htf_fvgs) - 1 to 0
            last_fvg = array.get(htf_fvgs, i)
            
            // Requisito: Mismo Timeframe, Misma Dirección y que siga Vivo
            if last_fvg.tf == tf_label and last_fvg.is_bull == is_bull_gap and not last_fvg.inverted
                
                // REGLA 1: Se superponen físicamente en el precio (Overlap)
                bool price_overlap = math.max(last_fvg.bot, new_bot) <= math.min(last_fvg.top, new_top)
                
                // REGLA 2: No se tocan, pero son "Stacked FVGs" (Se formaron casi enseguida en el mismo impulso)
                bool is_stacked = tf_mins > 0 and (t2 - last_fvg.last_time) <= max_time_dist
                
                if price_overlap or is_stacked
                    // --- FUSIÓN DE CAJAS (Nace el Liquidity Void) ---
                    last_fvg.top := math.max(last_fvg.top, new_top)
                    last_fvg.bot := math.min(last_fvg.bot, new_bot)
                    box.set_top(last_fvg.bx, last_fvg.top)
                    box.set_bottom(last_fvg.bx, last_fvg.bot)
                    box.set_right(last_fvg.bx, right_time)
                    
                    // --- FUSIÓN DEL CE (Línea central re-balanceada) ---
                    if show_htf_ce and not na(last_fvg.midline)
                        float new_mid = (last_fvg.top + last_fvg.bot) / 2
                        line.set_y1(last_fvg.midline, new_mid)
                        line.set_y2(last_fvg.midline, new_mid)
                        line.set_x2(last_fvg.midline, right_time)

                    last_fvg.last_time := t2
                    last_fvg.last_index := t1_index 
                    merged := true
                    break 

    // 2. SI NO HUBO FUSIÓN, CREAMOS UNO NUEVO
    if not merged
        if is_bull_gap 
            color border_c = show_htf_border ? c_htf_bull : color(na)
            box b = box.new(t2, new_top, right_time, new_bot, xloc=xloc.bar_time, text=tf_label, text_halign=text.align_right, text_valign=text.align_bottom, text_color=c_htf_lbl, text_size=sz_htf_lbl, border_color=border_c, bgcolor=c_htf_bull)
            
            line l = line(na)
            if show_htf_ce
                float mid_price = (new_top + new_bot) / 2
                l := line.new(t2, mid_price, right_time, mid_price, xloc=xloc.bar_time, color=htf_ce_color, style=htf_ce_style, width=1)
                
            array.push(htf_fvgs, HtfFvg.new(b, l, new_top, new_bot, true, false, tf_label, t2, t1_index))
            
        if is_bear_gap 
            color border_c = show_htf_border ? c_htf_bear : color(na)
            box b = box.new(t2, new_top, right_time, new_bot, xloc=xloc.bar_time, text=tf_label, text_halign=text.align_right, text_valign=text.align_bottom, text_color=c_htf_lbl, text_size=sz_htf_lbl, border_color=border_c, bgcolor=c_htf_bear)
            
            line l = line(na)
            if show_htf_ce
                float mid_price = (new_top + new_bot) / 2
                l := line.new(t2, mid_price, right_time, mid_price, xloc=xloc.bar_time, color=htf_ce_color, style=htf_ce_style, width=1)
                
            array.push(htf_fvgs, HtfFvg.new(b, l, new_top, new_bot, false, false, tf_label, t2, t1_index))

/// 🌟 FUNCIÓN DE EXTRACCIÓN ACTUALIZADA (Ahora extrae el ATR institucional)
f_htf_data() => [high[1], low[1], high[3], low[3], time[2], time[1], bar_index[1], ta.atr(14)]

if show_htf_fvg
    int chart_sec = timeframe.in_seconds(timeframe.period)

    // HTF 1H (60M)
    [h1_60, l1_60, h3_60, l3_60, t2_60, t1_60, t1_index_60, atr_60] = request.security(syminfo.tickerid, "60", f_htf_data(), lookahead=barmerge.lookahead_on)
    bool new_60m = ta.change(t1_60) != 0
    if new_60m and not na(t1_60) and chart_sec <= 3600
        f_create_htf_fvg(h1_60, l1_60, h3_60, l3_60, t2_60, t1_index_60, "1H FVG", atr_60)

    // HTF 15M
    [h1_15, l1_15, h3_15, l3_15, t2_15, t1_15, t1_index_15, atr_15] = request.security(syminfo.tickerid, "15", f_htf_data(), lookahead=barmerge.lookahead_on)
    bool new_15m = ta.change(t1_15) != 0
    if new_15m and not na(t1_15) and chart_sec <= 900
        f_create_htf_fvg(h1_15, l1_15, h3_15, l3_15, t2_15, t1_index_15, "15M FVG", atr_15)

    // HTF 5M
    [h1_5, l1_5, h3_5, l3_5, t2_5, t1_5, t1_index_5, atr_5] = request.security(syminfo.tickerid, "5", f_htf_data(), lookahead=barmerge.lookahead_on)
    bool new_5m = ta.change(t1_5) != 0
    if new_5m and not na(t1_5) and chart_sec <= 300
        f_create_htf_fvg(h1_5, l1_5, h3_5, l3_5, t2_5, t1_index_5, "5M FVG", atr_5)

    // LTF CURRENT 
    bool is_new_curr_bar = ta.change(time[1]) != 0
    
    // 🌟 EXTRAEMOS EL ATR AL ESPACIO GLOBAL PARA EVITAR EL WARNING 🌟
    float current_atr = ta.atr(14)
    
    if include_curr_tf and is_new_curr_bar
        string tf_str = timeframe.isseconds ? str.tostring(timeframe.multiplier) + "S FVG" : timeframe.isminutes ? str.tostring(timeframe.multiplier) + "M FVG" : timeframe.isdaily ? "D FVG" : timeframe.isweekly ? "W FVG" : "TF"
        f_create_htf_fvg(high[1], low[1], high[3], low[3], time[2], bar_index[1], tf_str, current_atr)
        
   // --- ANTI-STACKING VISUAL FILTER (Hierarchical Cleanup) ---
    if clean_stacked and array.size(htf_fvgs) > 1
        for i = array.size(htf_fvgs) - 1 to 0
            if i < array.size(htf_fvgs)
                f_child = array.get(htf_fvgs, i)
                if not f_child.inverted
                    bool is_overlapping = false
                    for j = 0 to array.size(htf_fvgs) - 1
                        if j < array.size(htf_fvgs) and i != j
                            f_parent = array.get(htf_fvgs, j)
                            if not f_parent.inverted and f_child.is_bull == f_parent.is_bull
                                int rank_c = f_child.tf == "1H FVG" ? 4 : f_child.tf == "15M FVG" ? 3 : f_child.tf == "5M FVG" ? 2 : 1
                                int rank_p = f_parent.tf == "1H FVG" ? 4 : f_parent.tf == "15M FVG" ? 3 : f_parent.tf == "5M FVG" ? 2 : 1
                                
                                if rank_p > rank_c
                                    if math.max(f_child.bot, f_parent.bot) < math.min(f_child.top, f_parent.top)
                                        is_overlapping := true
                                        break
                    if is_overlapping
                        box.delete(f_child.bx)
                        if not na(f_child.midline) // 🌟 Borrar el CE si se apila
                            line.delete(f_child.midline)
                        array.remove(htf_fvgs, i)

    // LÓGICA DE MITIGACIÓN, REBOTES Y LIMPIEZA DE ZOMBIS
    // 🌟 DETECTORES DE FRACTALES 🌟
    bool is_swing_low  = low[1] <= low[2] and low[1] <= low
    bool is_swing_high = high[1] >= high[2] and high[1] >= high

    if array.size(htf_fvgs) > 0
        for i = array.size(htf_fvgs) - 1 to 0
            f = array.get(htf_fvgs, i)
            bool deleted = false
            
            if not f.inverted
                if f.is_bull
                    if close < f.bot
                        // ❌ INVALIDACIÓN: El cuerpo rompió la zona por completo
                        if show_htf_inv
                            f.inverted := true
                            box.set_bgcolor(f.bx, c_htf_inv_bull)
                            box.set_border_color(f.bx, show_htf_border ? c_htf_inv_bull : color(na))
                            box.set_text(f.bx, f.tf + " (INV)") // Bonus: Le agrega "(INV)" si se vuelve IFVG
                        else
                            box.delete(f.bx)
                            if not na(f.midline) 
                                line.delete(f.midline)
                            array.remove(htf_fvgs, i)
                            deleted := true
                            
                    else 
                        // 🟢 REBOTE ALCISTA: Actualiza el texto de la caja
                        if is_swing_low and low[1] <= f.top and close[1] >= f.bot
                            box.set_text(f.bx, f.tf + " ▲")

                else // Es Bajista (Bearish)
                    if close > f.top
                        // ❌ INVALIDACIÓN: El cuerpo rompió la zona hacia arriba
                        if show_htf_inv
                            f.inverted := true
                            box.set_bgcolor(f.bx, c_htf_inv_bear)
                            box.set_border_color(f.bx, show_htf_border ? c_htf_inv_bear : color(na))
                            box.set_text(f.bx, f.tf + " (INV)") // Bonus: Le agrega "(INV)" si se vuelve IFVG
                        else
                            box.delete(f.bx)
                            if not na(f.midline) 
                                line.delete(f.midline)
                            array.remove(htf_fvgs, i)
                            deleted := true
                            
                    else 
                        // 🔴 REBOTE BAJISTA: Actualiza el texto de la caja
                        if is_swing_high and high[1] >= f.bot and close[1] <= f.top
                            box.set_text(f.bx, f.tf + " ▼")

            else // --- Lógica de IFVGs (Invertidos) ---
                if f.is_bull 
                    if high >= f.top
                        box.delete(f.bx)
                        if not na(f.midline) 
                            line.delete(f.midline)
                        array.remove(htf_fvgs, i)
                        deleted := true
                else 
                    if low <= f.bot
                        box.delete(f.bx)
                        if not na(f.midline) 
                            line.delete(f.midline)
                        array.remove(htf_fvgs, i)
                        deleted := true

            if not deleted
                int right_time_upd = time + (extend_htf * one_bar_ms)
                box.set_right(f.bx, right_time_upd)
                if show_htf_ce and not na(f.midline) 
                    line.set_x2(f.midline, right_time_upd)

        // GC Optimizado: Limpieza segura de HTF FVGs (Anti-Borrado de HTF)
        int actual_max_fvgs = include_curr_tf ? max_htf_fvgs + 15 : max_htf_fvgs
        while array.size(htf_fvgs) > actual_max_fvgs
            HtfFvg oldest = array.shift(htf_fvgs)
            if not na(oldest.bx)
                box.delete(oldest.bx)
            if not na(oldest.midline) // 🌟 Limpiar memoria del CE viejo
                line.delete(oldest.midline)
                
// =============================================================================
// --- 4. SMT PRO+ SETTINGS ---
// =============================================================================
grp_smt   = "SMT"

smt_corr_mode = input.string("Automatic", "Correlated Asset", options=["Automatic", "Manual"], group=grp_smt, display=display.none)
smt_manual_sym= input.symbol("CME_MINI:ES1!", "", group=grp_smt, display=display.none)

