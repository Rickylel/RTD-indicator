c_smt_bull    = input.color(color.rgb(0, 0, 0), "Bullish:", inline="smt_bull", group=grp_smt, display=display.none)
sz_bull_w     = input.string("Thin", "", options=["Thin", "Medium", "Thick"], inline="smt_bull", group=grp_smt, display=display.none)
st_bull_s     = input.string("Solid", "", options=["Solid", "Dashed", "Dotted"], inline="smt_bull", group=grp_smt, display=display.none)

c_smt_bear    = input.color(color.rgb(0, 0, 0), "Bearish:", inline="smt_bear", group=grp_smt, display=display.none)
sz_bear_w     = input.string("Thin", "", options=["Thin", "Medium", "Thick"], inline="smt_bear", group=grp_smt, display=display.none)
st_bear_s     = input.string("Solid", "", options=["Solid", "Dashed", "Dotted"], inline="smt_bear", group=grp_smt, display=display.none)

smt_show_lbl  = input.bool(true, "Label", inline="smt_lbl", group=grp_smt, display=display.none)
c_smt_lbl     = input.color(color.gray, "", inline="smt_lbl", group=grp_smt, display=display.none)
smt_lbl_sz    = input.string("Tiny", "Size", options=["Tiny", "Small", "Normal"], inline="smt_lbl", group=grp_smt, display=display.none)
