setup_look   = input.int(15, "Setup Validation Window (Bars)", group=grp_style, display=display.none)
req_sweep    = input.bool(true, "Require Liquidity Sweep for Entry", tooltip="If disabled, it will mark valid iFVGs even if no Sweep occurred.", group=grp_style, display=display.none)
req_pda_vip  = input.bool(true, "Allow HTF FVG Reaction", tooltip="If enabled, bouncing from an HTF FVG will validate the setup even without a Liquidity Sweep.", group=grp_style, display=display.none)
show_hover   = input.bool(true, "Show Confluences on Hover", group=grp_style, display=display.none) 
c_bull_box   = input.color(color.new(#0f0f0f, 60), "Bullish Box", group=grp_style, display=display.none)
