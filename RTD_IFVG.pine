// --- CONVERSIÓN DINÁMICA DE TAMAÑO Y POSICIÓN (STATS) ---
var string stats_pos_real = position.bottom_left
if stats_pos_str == "Top Right"
    stats_pos_real := position.top_right
else if stats_pos_str == "Middle Right"
