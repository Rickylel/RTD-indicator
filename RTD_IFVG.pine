// --- FUNCIONES DE ESTILO SMT ---
f_get_width(w_str) =>
    w_str == "Thin" ? 1 : w_str == "Medium" ? 2 : 3

f_get_style(s_str) =>
    s_str == "Solid" ? line.style_solid : s_str == "Dashed" ? line.style_dashed : line.style_dotted

f_get_size(sz_str) =>
    sz_str == "Tiny" ? size.tiny : sz_str == "Small" ? size.small : size.normal

// --- EMPAREJAMIENTO AUTOMÁTICO ---
f_get_auto_sym() =>
    string t = syminfo.ticker
    string pref = syminfo.prefix + ":"
    if str.contains(t, "NQ")
        pref + "ES1!"
    else if str.contains(t, "ES")
        pref + "NQ1!"
    else if str.contains(t, "YM")
        pref + "ES1!"
    else if str.contains(t, "GC")
        pref + "SI1!"
    else
        smt_manual_sym

string target_sym = smt_corr_mode == "Automatic" ? f_get_auto_sym() : smt_manual_sym

f_short_sym(s) =>
    arr = str.split(s, ":")
    string raw_name = array.get(arr, array.size(arr) - 1)
    str.replace_all(raw_name, "1!", "") 

string lbl_text_base = smt_show_sym ? "SMT w/ " + f_short_sym(target_sym) : "SMT"

// (Mantenemos los inputs de ENTRY SETUPS igual)
